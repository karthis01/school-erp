<?xml version="1.0" encoding="UTF-8"?>
<configuration>

    <!-- Pull in Spring Boot's default console pattern/colors -->
    <include resource="org/springframework/boot/logging/logback/defaults.xml"/>

    <property name="LOG_DIR" value="logs"/>

    <!-- Normal app console output (unchanged behaviour) -->
    <appender name="CONSOLE" class="ch.qos.logback.core.ConsoleAppender">
        <encoder>
            <pattern>${CONSOLE_LOG_PATTERN}</pattern>
        </encoder>
    </appender>

    <!-- Dedicated SQL query log file, rolled daily, keeps last 14 files -->
    <appender name="SQL_FILE" class="ch.qos.logback.core.rolling.RollingFileAppender">
        <file>${LOG_DIR}/sql.log</file>
       <rollingPolicy class="ch.qos.logback.core.rolling.TimeBasedRollingPolicy">
			<fileNamePattern>logs/sql.%d{yyyy-MM-dd}.log</fileNamePattern>
			<maxHistory>14</maxHistory>
			<totalSizeCap>200MB</totalSizeCap>
		</rollingPolicy>
        <encoder>
            <pattern>%d{yyyy-MM-dd HH:mm:ss.SSS} [%thread] %-5level %logger{36} - %msg%n</pattern>
        </encoder>
    </appender>

    <!-- org.hibernate.SQL logs the actual SQL statement (with format_sql applied) -->
    <logger name="org.hibernate.SQL" level="DEBUG" additivity="false">
        <appender-ref ref="SQL_FILE"/>
    </logger>

    <!-- Logs the actual bound parameter values (Hibernate 6 binder logger) -->
    <logger name="org.hibernate.orm.jdbc.bind" level="TRACE" additivity="false">
        <appender-ref ref="SQL_FILE"/>
    </logger>

    <!-- Root logger: everything else keeps going to the console as before -->
    <root level="INFO">
        <appender-ref ref="CONSOLE"/>
    </root>

</configuration>
