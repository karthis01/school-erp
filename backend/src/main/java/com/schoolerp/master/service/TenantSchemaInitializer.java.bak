package com.schoolerp.master.service;

import com.schoolerp.entity.*;
import org.hibernate.boot.Metadata;
import org.hibernate.boot.MetadataSources;
import org.hibernate.boot.registry.StandardServiceRegistry;
import org.hibernate.boot.registry.StandardServiceRegistryBuilder;
import org.hibernate.tool.schema.spi.SchemaManagementToolCoordinator;
import org.springframework.stereotype.Component;
import org.hibernate.boot.model.naming.CamelCaseToUnderscoresNamingStrategy;

import javax.sql.DataSource;
import java.sql.Connection;
import java.sql.SQLException;
import java.util.Map;

/**
 * When a brand-new school is registered, its database is empty. Because Hibernate only
 * runs ddl-auto=update once, at application startup (see TenantPersistenceConfig), that
 * won't create tables for schools registered afterwards. This class builds a one-off,
 * throwaway Hibernate metadata model from the same @Entity classes and runs a CREATE
 * against the new school's DataSource directly, using Hibernate's programmatic schema
 * tooling entry point (SchemaManagementToolCoordinator - the modern replacement for the
 * old, now-removed org.hibernate.tool.hbm2ddl.SchemaExport class).
 *
 * Existing schools whose database already has tables should be registered with
 * initializeSchema=false to skip this step.
 */
@Component
public class TenantSchemaInitializer {

