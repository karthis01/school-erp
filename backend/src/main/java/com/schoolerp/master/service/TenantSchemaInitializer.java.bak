	public void createSchema(DataSource dataSource) {
    try (Connection ignored = dataSource.getConnection()) {
        // just verifying the connection works before we do anything destructive
    } catch (SQLException e) {
        throw new IllegalStateException("Could not connect to the new school's database: " + e.getMessage(), e);
    }

    StandardServiceRegistry registry = new StandardServiceRegistryBuilder()
            .applySetting("hibernate.connection.datasource", dataSource)
            .applySetting("hibernate.dialect", "org.hibernate.dialect.MySQLDialect")
            .build();

    try {
        MetadataSources sources = new MetadataSources(registry)
                .addAnnotatedClass(User.class)
                .addAnnotatedClass(Staff.class)
                .addAnnotatedClass(SchoolClass.class)
                .addAnnotatedClass(Student.class)
                .addAnnotatedClass(Attendance.class)
                .addAnnotatedClass(FeeStructure.class)
                .addAnnotatedClass(FeePayment.class)
                .addAnnotatedClass(SchoolSettings.class);

        Metadata metadata = sources.getMetadataBuilder()
                .applyPhysicalNamingStrategy(new SpringPhysicalNamingStrategy())
                .applyImplicitNamingStrategy(new SpringImplicitNamingStrategy())
                .build();

        Map<String, Object> settings = Map.of(
                "hibernate.hbm2ddl.auto", "create",
                "hibernate.hbm2ddl.halt_on_error", true
        );

        SchemaManagementToolCoordinator.process(metadata, registry, settings, action -> {
            // no delayed "create-drop" behaviour needed - we only ever CREATE here
        });
    } finally {
        StandardServiceRegistryBuilder.destroy(registry);
    }
}
}
